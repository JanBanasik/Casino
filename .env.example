# ─────────────────────────────────────────────────────────────────────────────
# Szablon zmiennych środowiskowych dla PRODUKCJI (Docker Compose).
# Skopiuj do `.env` i uzupełnij wartości:   cp .env.example .env
# Ten plik czyta `docker-compose.prod.yml` (cel `make prod-up`).
# NIE commituj swojego `.env` — jest w .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Baza danych (PostgreSQL) ────────────────────────────────────────────────
POSTGRES_USER=casino
POSTGRES_PASSWORD=casino
POSTGRES_DB=casino

# ── Bezpieczeństwo ──────────────────────────────────────────────────────────
# WYMAGANE. Wygeneruj: openssl rand -hex 32
JWT_SECRET_KEY=changeme-openssl-rand-hex-32

# Dozwolone originy CORS (URL frontendu, oddzielone przecinkami).
CORS_ORIGINS=http://localhost:8080

# Port, na którym wystawiony jest frontend (nginx).
FRONTEND_PORT=8080

# ── Płatności (Stripe) ──────────────────────────────────────────────────────
# Zostaw puste, by działać w trybie SYMULACJI (żetony dopisywane od razu, bez
# realnego obciążenia karty). Uzupełnij kluczami testowymi, by włączyć Checkout.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Dokąd Stripe odsyła gracza po płatności / anulowaniu.
PAYMENT_SUCCESS_URL=http://localhost:8080/konto?purchase=success
PAYMENT_CANCEL_URL=http://localhost:8080/konto?purchase=cancel
