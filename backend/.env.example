# ─────────────────────────────────────────────────────────────────────────────
# Szablon zmiennych środowiskowych dla DEVELOPMENTU backendu (`make dev`).
# Skopiuj do backend/.env i uzupełnij:   cp backend/.env.example backend/.env
# Infrastruktura z `make docker-up` wystawia Postgresa na :15432, Redisa na :16379.
# NIE commituj swojego backend/.env — jest w .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Połączenia ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://casino:casino@localhost:15432/casino
REDIS_URL=redis://localhost:16379/0

# ── Bezpieczeństwo ──────────────────────────────────────────────────────────
# WYMAGANE. Wygeneruj: openssl rand -hex 32
JWT_SECRET_KEY=changeme-openssl-rand-hex-32
DEBUG=true

# Dozwolone originy CORS (URL frontendu dev, oddzielone przecinkami).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Płatności (Stripe) ──────────────────────────────────────────────────────
# Puste = tryb SYMULACJI (bez realnych obciążeń). Uzupełnij kluczami testowymi,
# by włączyć prawdziwy Checkout. Webhook lokalnie: `stripe listen --forward-to
# localhost:8000/api/payments/webhook` (sekret z tej komendy → STRIPE_WEBHOOK_SECRET).
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

PAYMENT_SUCCESS_URL=http://localhost:5173/konto?purchase=success
PAYMENT_CANCEL_URL=http://localhost:5173/konto?purchase=cancel
